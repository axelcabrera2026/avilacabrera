<svg width="800" height="420" viewBox="0 0 800 420" xmlns="http://www.w3.org/2000/svg">

  <!-- Fondo -->
  <rect width="100%" height="100%" fill="#0b0f14"></rect>

  <!-- Gradiente -->
  <defs>
    <linearGradient id="gradMain" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#00e676"></stop>
      <stop offset="100%" stop-color="#00b0ff"></stop>
    </linearGradient>
  </defs>

  <!-- Ícono POS (BAJADO y centrado correctamente) -->
  <g transform="translate(330,80)">
    <!-- pantalla -->
    <rect x="0" y="0" width="140" height="80" rx="10" fill="none" stroke="url(#gradMain)" stroke-width="3"></rect>
    
    <!-- carrito -->
    <polyline points="20,20 35,20 45,50 90,50" fill="none" stroke="#00e676" stroke-width="3"></polyline>
    <circle cx="55" cy="60" r="5" fill="#00e676"></circle>
    <circle cx="85" cy="60" r="5" fill="#00e676"></circle>
  </g>

  <!-- Texto principal -->
  <text x="50%" y="60%" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="72" font-weight="700" fill="url(#gradMain)" letter-spacing="5">
    SOFTWARE
  </text>

  <!-- A.C -->
  <text x="50%" y="76%" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="36" fill="#00e676" letter-spacing="12">
    A.C
  </text>

  <!-- Subtítulo -->
  <text x="50%" y="90%" text-anchor="middle" font-family="Segoe UI, Arial, sans-serif" font-size="20" fill="#9aa4ad" letter-spacing="3">
    SISTEMA DE PUNTO DE VENTA
  </text>

</svg>
